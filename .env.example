# ===========================================
# Firebase Configuration
# ===========================================
# Get these values from your Firebase Console:
# 1. Go to https://console.firebase.google.com
# 2. Select your project (or create one)
# 3. Click the gear icon > Project settings
# 4. Scroll down to "Your apps" and select your web app
# 5. Copy the config values below

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-your_measurement_id

# ===========================================
# Admin Credentials (for demo purposes)
# ===========================================
# In production, use Firebase Authentication instead
ADMIN_EMAIL=demo@archstudio.com
ADMIN_PASSWORD=your_demo_password_here

# ===========================================
# Firebase Admin SDK (Server-side)
# ===========================================
# Required for server-side Firebase features (API routes, server actions)
# 
# Option 1: Use individual environment variables (recommended for Vercel)
FIREBASE_ADMIN_PROJECT_ID=your_project_id_here
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Option 2: Use service account JSON file (for local development)
# 1. Go to Firebase Console > Project Settings > Service Accounts
# 2. Click "Generate new private key"
# 3. Save the downloaded JSON file as "service-account-key.json" in the project root
# 4. IMPORTANT: Add "service-account-key.json" to your .gitignore (already done)
# 
# The file should look like service-account-key.example.json
